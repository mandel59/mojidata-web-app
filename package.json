    "visual:compare": "node scripts/run-visual-suite.mjs compare",
    "visual:refresh-baseline": "node scripts/run-visual-suite.mjs refresh-baseline",
    "compare:styles": "node scripts/compare-rendered-styles.mjs",
    "compare:mojidata:layout": "node scripts/compare-mojidata-layout.mjs",
