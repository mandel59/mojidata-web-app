{
  "name": "mojidata-web-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare:spa-assets": "node scripts/copy-spa-assets.mjs",
    "predev": "npm run prepare:spa-assets",
    "dev": "next dev --webpack",
    "prebuild": "npm run prepare:spa-assets",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:js": "eslint",
    "lint:css": "stylelint 'src/**/*.css'",
