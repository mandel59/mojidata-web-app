{
  "name": "mojidata-web-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare:spa-assets": "node scripts/copy-spa-assets.mjs",
    "predev": "npm run prepare:spa-assets",
    "dev": "next dev --webpack",
    "prebuild": "npm run prepare:spa-assets",
    "build": "next build --webpack",
    "start": "next start",
    "cf:clean-cache": "node scripts/clean-cloudflare-build-cache.mjs",
    "cf:build": "npm run cf:clean-cache && node scripts/check-cloudflare-build-assets.mjs && MOJIDATA_SKIP_SPA_ASSETS=1 opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare preview",
    "cf:deploy": "opennextjs-cloudflare deploy",
    "cf:upload": "opennextjs-cloudflare upload",
    "cf:populate-cache": "opennextjs-cloudflare populateCache",
    "cf:typegen": "wrangler types",
    "cf:upload-spa-assets": "node scripts/upload-spa-assets-to-r2.mjs",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:js": "eslint",
    "lint:css": "stylelint 'src/**/*.css'",
    "refresh:storybook-fixtures": "./scripts/refresh-storybook-svg-fixtures.sh",
    "test:e2e": "playwright test",
    "test:e2e:target": "node scripts/run-playwright-target.mjs",
    "test:sequential": "node scripts/run-sequential.mjs",
    "verify:ui:sequential": "node scripts/run-sequential.mjs --cmd \"npm run test:e2e:target -- -- 'tests/e2e/chrome-visual.spec.ts' --project=chromium\" --cmd \"npm run test:e2e:target -- -- 'tests/e2e/search-visual.spec.ts' --project=chromium\" --cmd \"npm run test:e2e:target -- -- 'tests/e2e/mojidata.spec.ts' --project=chromium --grep 'desktop mojidata keeps the TOC sidebar beside the main content|moji_joho display mode toggles without route refetch'\" --cmd \"npm run test:e2e:target -- -- 'tests/e2e/bot-rewrite.spec.ts' --project=chromium --grep 'mobile non-SPA search page can use search examples|mobile non-SPA search results page keeps form usable|mobile non-SPA idsfind results page keeps form usable'\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "storybook:smoke": "node scripts/run-storybook-smoke.mjs",
    "storybook:visual": "node scripts/run-storybook-smoke.mjs --spec tests/e2e/storybook-visual.spec.ts",
    "visual:compare": "node scripts/run-visual-suite.mjs compare",
    "visual:compare:3000": "node scripts/run-visual-suite.mjs compare --port 3000",
    "visual:refresh-baseline": "node scripts/run-visual-suite.mjs refresh-baseline",
    "verify:style-system": "node scripts/run-sequential.mjs --cmd \"npm run build-storybook\" --cmd \"npm run storybook:smoke\" --cmd \"npm run storybook:visual\" --cmd \"npm run visual:compare\"",
    "compare:styles": "node scripts/compare-rendered-styles.mjs",
    "compare:mojidata:layout": "node scripts/compare-mojidata-layout.mjs",
    "compare:mojidata:sections": "node scripts/compare-mojidata-sections.mjs",
    "compare:mojidata:regional": "node scripts/compare-mojidata-regional-section.mjs"
  },
  "dependencies": {
    "@mandel59/idsdb": "^1.7.0",
    "@mandel59/idsdb-utils": "^1.7.0",
    "@mandel59/mojidata": "^1.7.2",
    "@mandel59/mojidata-api": "^1.7.5",
    "@types/node": "^20.3.0",
    "@types/react": "^18.2.11",
    "@types/react-dom": "^18.2.4",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "autoprefixer": "10.4.14",
    "clsx": "^2.1.1",
    "next": "^16.0.10",
    "opentype.js": "^1.3.4",
    "postcss": "^8.4.24",
    "raw-loader": "^4.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "resolve-accept-language": "^3.1.4",
    "typescript": "^5.3.2"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.5",
    "@playwright/test": "^1.51.1",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/nextjs": "^10.3.3",
    "@types/opentype.js": "^1.3.9",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.0",
    "eslint-plugin-storybook": "^10.3.3",
    "storybook": "^10.3.3",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "wrangler": "^4.87.0"
  }
}
